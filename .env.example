# Anthropic — required for all AI agent calls
ANTHROPIC_API_KEY=

# Database — Supabase PostgreSQL connection string (use the "Transaction" pooler URL on Vercel)
DATABASE_URL=

# GitHub — Personal Access Token with scopes: repo, read:org
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# LangSmith observability — optional; tracing is disabled when unset
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=
LANGSMITH_PROJECT=

# Browser health checks — optional; used by the Playwright tool
STAGING_URL=
